/* Estilo geral */
body {
  background-color: #0a0a0a;
  color: #fff;
  font-family: 'Orbitron', sans-serif;
  margin: 0;
  text-align: center;
}

/* Cabeçalho */
header {
  background: linear-gradient(90deg, #ff0000, #660000);
  padding: 20px;
  font-size: 2em;
  font-weight: bold;
  border-bottom: 3px solid #fff;
}

/* Navegação */
nav {
  margin: 20px;
}
nav a {
  color: #fff;
  text-decoration: none;
  margin: 0 15px;
  font-weight: bold;
}
nav a:hover {
  color: #ff0000;
}

/* Imagens */
img {
  width: 90%;
  max-width: 1000px;
  margin: 20px auto;
  border: 3px solid #ff0000;
  border-radius: 10px;
}

/* Blocos de membros */
.membro {
  margin: 30px auto;
  width: 80%;
  max-width: 800px;
  border: 2px solid #ff0000;
  border-radius: 10px;
  padding: 20px;
  background-color: #1a1a1a;
}
.membro img {
  width: 100%;
  border-radius: 10px;
}

/* Rodapé */
footer {
  margin-top: 40px;
  font-size: 0.9em;
  color: #aaa;
  padding-bottom: 20px;
}
